# ローカル開発用の環境変数サンプル。これをコピーして .env を作成してください。
# Render 上では Render のダッシュボードから環境変数を設定するため、このファイルは使いません。

# Postgres の接続文字列。ローカル開発時は localhost を指定。
DATABASE_URL=postgres://postgres:postgres@localhost:5432/othello

# 任意のランダム文字列（32文字以上推奨）。本番では必ず設定すること。
JWT_SECRET=please-change-me-to-a-long-random-string

# ローカルの Postgres で SSL を使わない場合は 'disable' を指定
PGSSL=disable

# 任意。デフォルトは 3000
PORT=3000
